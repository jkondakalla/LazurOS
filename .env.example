# LazurOS — environment variables
# Copy this to .env and fill in all values.

# ── JWT auth (must match ordeck auth-api exactly) ─────────────────────────────
JWT_SECRET=YOUR_JWT_SECRET_MIN_64_CHARS

# ── CORS: ORDECK shell origin ─────────────────────────────────────────────────
SHELL_URL=https://YOUR_DOMAIN

# ── Comma-separated allowed Google emails (empty = any Google account) ─────────
ALLOWED_EMAILS=

# ── Compute node (the Linux desktop running Ollama) ──────────────────────────
COMPUTE_NODE_IP=192.168.X.XXX
COMPUTE_NODE_MAC=XX:XX:XX:XX:XX:XX
COMPUTE_API_PORT=11434

# ── LazurOS listen port (also hardcoded in Dockerfile — change both if needed) ─
LAZUROS_LISTEN_PORT=8080

# ── How long to wait for compute node to boot before returning 503 ─────────────
WAKE_TIMEOUT_SECONDS=45
