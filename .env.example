# IP address of the Linux desktop (compute node)
COMPUTE_NODE_IP=192.168.1.100

# MAC address of the compute node's NIC (for Wake-on-LAN)
COMPUTE_NODE_MAC=AA:BB:CC:DD:EE:FF

# Port the inference engine (Ollama/vLLM) listens on
COMPUTE_API_PORT=11434

# Port LazurOS binds to on TrueNAS (only used in bridge networking mode)
LAZUROS_LISTEN_PORT=8080

# How long to wait for the compute node to wake before returning 503
WAKE_TIMEOUT_SECONDS=45
